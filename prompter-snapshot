#!/usr/bin/env bash
# Quick menu debug — run from repo root (needs scripts/ from ./bootstrap-dev.sh)
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
PY="${ROOT}/scripts/prompter-menu.py"
[[ -f "${PY}" ]] || {
  echo "Missing ${PY} — run: ./bootstrap-dev.sh" >&2
  exit 1
}
exec python3 "${PY}" snapshot "${ROOT}" "$@"
